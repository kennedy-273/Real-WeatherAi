{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/server.js": {
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/weather(.*)",
      "destination": "/api/weather"
    },
    {
      "source": "/(.*)",
      "destination": "/api/server"
    }
  ]
}