{
  "version": 2,
  "buildCommand": "npm run build",
  "build": {
    "env": [
      "WEATHER_AI_KEY"
    ]
  },
  "functions": {
    "dist/server/server.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/dist/server/server.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "HEAD", "OPTIONS"]
    },
    {
      "src": "/(.*\\.(js|css|txt|svg|png|jpg|jpeg|gif|webp|woff|woff2|ttf|eot|otf))",
      "dest": "/dist/client/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/server/server.js"
    }
  ]
}
